# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/security_monitor
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Application
APP_NAME=Security Monitoring API
ENVIRONMENT=development
FRONTEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Authentication
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_FAIL_WINDOW_SECONDS=900

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# OAuth - Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

# Stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_ID=
STRIPE_PRICE_PRO_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# AI Service
GROQ_API_KEY=